# Copy this file to `.env` and set the value for THIS environment.
# `.env` is git-ignored, so local and server each keep their own.
#
# Where the browser downloads the Coding Agent widget from:
#   • Local dev  → http://127.0.0.1:5179/widget.js   (companion runs on your own machine)
#   • Server     → /widget.js                          (nginx routes it to the companion)
#
# After changing this, restart the app (Next reads .env only at startup): pm2 restart app
UIED_WIDGET_URL=http://127.0.0.1:5179/widget.js
